spring.application.name=ecommerce
# db source
spring.datasource.url=jdbc:mysql://localhost:3306/your_db_name
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password

# auto add/delete table
spring.jpa.hibernate.ddl-auto=update

# show SQL script in the console
spring.jpa.show-sql=true

# Signer key for JWT (Needs to be a long secret string for HS512)
jwt.signerKey=your_very_long_and_secure_secret_key_for_jwt_signature_validation

# Vnpay sandbox config
vnp_PayUrl=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
vnp_ReturnUrl=http://localhost:8080/api/payment/vnpay-callback
vnp_TmnCode=YOUR_VN_PAY_TMN_CODE
vnp_HashSecret=YOUR_VN_PAY_HASH_SECRET
vnp_ApiUrl=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
